@3000 = "Rozjuszenie"
@3001 = "Rozjuszenie

Stworzenie używające tej zdolności wpada w szał, otrzymując premię 1k6 do Siły i Kondycji oraz odporność na Zauroczenie, Ogłupienie i Zamęt.
Czas działania: 5 rund +1 runda co 5 poziomów.
"
@3002 = "Olbrzymi dzik"
@3003 = "Nie możesz użyć tej zdolności, dopóki poprzednia zdolność wciąż działa"

