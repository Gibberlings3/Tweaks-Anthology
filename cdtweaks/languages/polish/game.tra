@318313 = ~Sprowadź tu moją ukochaną, Aerie.~
@318314 = ~Sprowadź tu moją ukochaną, Jaheirę.~
@318315 = ~Sprowadź tu mojego ukochanego Rycerza Zakonu, Sir Anomena.~
@318316 = ~Sprowadź tu mojego ukochanego, Anomena, kapłana Helma.~
@318317 = ~Sprowadź tu moją ukochaną, Viconię.~
@318318 = ~Sprowadź tu mojego ukochanego, Dorna.~
@318319 = ~Sprowadź tu moją ukochaną, Hexxat.~
@318320 = ~Sprowadź tu moją ukochaną, Neerę.~
@318321 = ~Sprowadź tu mojego ukochanego, Rassada.~

@322001 = ~Atta~
@322002 = ~Aniołek~

@324101 = ~Dżin żetonów~
@324102 = ~Żeton~
@324103 = ~Niepozorny żeton bez żadnych oznaczeń.~
@324104 = ~Witaj! Wybierz przedmiot, na który chcesz wymienić swój żeton:~

@324201 = ~Flynn~
@324202 = ~Wędrowny kupiec~
@324203 = ~Harrold~
@324204 = ~Witajcie, podróżnicy! Mogę zająć wam chwilę?~
@324205 = ~Wybacz, teraz nie mam czasu.~
@324206 = ~Wybaczcie zamieszanie, ale nie mam żadnych towarów na sprzedaż. Szukam za to egzotycznych przedmiotów, choć nie płacę za nie złotem.~
@324207 = ~Oczywiście wszystko to... za niewielką prowizję.~
@324208 = ~Może innym razem.~
@324209 = ~Co to za prowizja?~
@324210 = ~Zwykle pobieram tysiąc sztuk złota, ale w zamian mogę zaoferować szeroki wybór wymian.~
@324211 = ~To strasznie dużo!~
@324212 = ~Dobrze więc. Mam coś, co mogłoby cię zainteresować?~
@324213 = ~To prawda, ale moja oferta nie ma sobie równych. A samo oglądanie nic nie kosztuje.~
@324214 = ~Żegnajcie i szerokiej drogi.~
@324215 = ~Dobrze słyszeć, że dotarł bezpiecznie. Czyli już wiesz, jak to działa?~
@324216 = ~Tak. Mógłbyś rzucić okiem na moje towary i sprawdzić, czy mam coś wartego wymiany?~
@324217 = ~Nie, właściwie nie.~
@324218 = ~Chętnie wymienię swoje egzotyczne towary na wszystko, co uda ci się znaleźć. Może mam coś bardziej przydatnego dla kogoś takiego jak ty.~
@324219 = ~No dobrze, zobaczmy...~
@324220 = ~Witajcie ponownie, podróżnicy.~
@324221 = ~Niestety nie widzę tu niczego, co by mnie interesowało.~
@324222 = ~Chciałbym zdobyć te przedmioty. Chcesz zobaczyć, co mogę zaoferować w zamian?~
@324223 = ~Nie zamierzam wymieniać żadnej z tych rzeczy.~
@324224 = ~Och... wygląda na to, że nie masz dość złota, by opłacić moją prowizję.~
@324225 = ~Dobrze więc. Któryś z tych przedmiotów cię interesuje?~
@324226 = ~Niestety nie. Co jeszcze możemy wymienić?~
@324227 = ~Dobrze.~
@324228 = ~Dziękuję. Żegnaj.~
// -60 and -80 string series are identical, just with Flynn/Harrold and Lonelywood/Kuldahar exchanged
@324260 = ~Jestem Flynn, przedstawiciel kompanii handlowej z Calimportu. Przysłano mnie tutaj, bym wyszukiwał egzotyczne i unikatowe przedmioty.~
@324261 = ~Zdaje się, że spotkałem twojego odpowiednika, Harrolda, w Samotnej Kniei.~
@324262 = ~Miło cię poznać, Flynnie. Mogę zobaczyć twoje towary?~
@324263 = ~Dzięki, Flynnie. Będę o tobie pamiętać, jeśli coś znajdę.~
@324264 = ~Witaj ponownie, Flynnie. Możemy się znowy wymienić?~
@324265 = ~Nie, nic z tego mnie nie interesuje. Żegnaj, Flynnie.~
@324266 = ~Dziękuję, Flynnie. Masz może jeszcze coś na wymianę?~
@324280 = ~Jestem Harrold, przedstawiciel kompanii handlowej z Calimportu. Przysłano mnie tutaj, bym wyszukiwał egzotyczne i unikatowe przedmioty.~
@324281 = ~Zdaje się, że spotkałem twojego odpowiednika, Flynna, w Kuldahar.~
@324282 = ~Miło cię poznać, Harroldzie. Mogę zobaczyć twoje towary?~
@324283 = ~Dzięki, Harroldzie. Będę o tobie pamiętać, jeśli coś znajdę.~
@324284 = ~Witaj ponownie, Harroldzie. Chcesz coś tutaj wymienić?~
@324285 = ~Nie, nic z tego mnie nie interesuje. Żegnaj, Harroldzie.~
@324286 = ~Dziękuję, Harroldzie. Masz może jeszcze coś na wymianę?~

@325001 = ~Właściwie, możemy jeszcze raz zobaczyć przedmioty, które oferowałeś, kiedy po raz pierwszy przybyliśmy do Kuldahar?~
@325002 = ~Możemy jeszcze raz obejrzeć przedmioty, które oferowałeś później, podczas naszego pobytu tutaj?~

