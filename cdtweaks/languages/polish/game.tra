@244002 = ~Tabela Biegłości:~ // line before <DOTS1>, exclude the * if present
// get @244003 from string 32117 (bg2ee/iwdee) or 24220 (bgee)
@244003 = ~(tylko dla wojowników)~

@274001 = ~Nie może używać pancerza podczas przemian~

